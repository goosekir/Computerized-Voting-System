{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["electionId", "tokenHash", "status", "issuedAt"],
    "properties": {
      "electionId": {
        "bsonType": "objectId"
      },
      "tokenHash": {
        "bsonType": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "status": {
        "bsonType": "string",
        "enum": ["ACTIVE", "USED", "REVOKED"]
      },
      "issuedAt": {
        "bsonType": "date"
      },
      "usedAt": {
        "bsonType": ["date", "null"]
      }
    },
    "additionalProperties": true
  }
}